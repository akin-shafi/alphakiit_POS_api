# Server
APP_PORT=5050
ENV=development

# Database
# Local:
# DATABASE_URL=postgres://username:password@localhost:5432/database_name?sslmode=disable

# Remote:
DATABASE_URL=postgres://username:password@host:port/database_name?sslmode=require

# Authentication
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_smtp_password_here

SMTP_FROM="Your App Name <no-reply@example.com>"
SMTP_TLS=true

# App Configuration
APP_NAME=Your App Name
APP_URL=https://your-app-domain.com
SUPPORT_EMAIL=support@example.com

# API Host
# Production:
# API_HOST=https://api.your-app-domain.com

# Local:
API_HOST=http://localhost:8080

# Allowed Frontend Origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173

# Render (optional)
# RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URL=http://localhost:5050/api/v1/google/callback
FRONTEND_URL=https://your-frontend-domain.com

# Twilio / WhatsApp
TWILIO_ACCOUNT_SID=AC_your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890
WHATSAPP_SANDBOX_NUMBER=whatsapp:+14155238886

# Internal API Authentication
INTERNAL_API_KEY=your_internal_api_key